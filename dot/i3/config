exec_always --no-startup-id autotiling
exec_always --no-startup-id dropbox
exec_always --no-startup-id xset r rate 250 20
exec_always --no-startup-id albert
exec_always --no-startup-id xinput set-prop 11 312 1
exec_always --no-startup-id xinput set-prop 11 314 0
exec_always --no-startup-id xinput set-prop 11 324 0.4
exec_always --no-startup-id xinput set-prop 11 333 10 
exec_always --no-startup-id xinput set-prop 15 304 1
exec_always --no-startup-id xinput set-prop 15 317 0
exec_always --no-startup-id xinput set-prop 15 327 0.4
exec_always --no-startup-id xinput set-prop 15 334 10 
exec_always --no-startup-id xinput set-prop 14 312 1
exec_always --no-startup-id xinput set-prop 14 314 0
exec_always --no-startup-id xinput set-prop 14 324 0.4
exec_always --no-startup-id xinput set-prop 14 333 10 
# exec_always --no-startup-id setxkbmap -option caps:swapescape

# Workspace
assign [class="obsidian"] 1
assign [class="Todoist"] 3
assign [class="RemNote"] 4

# Open App
bindsym $mod+F1 exec ~/Applications/./Obsidian-0.15.9.AppImage
bindsym $mod+F3 exec nautilus ~/Dropbox
bindsym $mod+F2 exec firefox 
bindsym $mod+F4 exec ./pkill.sh 
